{
  "name": "vite-start-antd",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "format": "prettier \"**/*\" --write --ignore-unknown",
    "lint": "eslint . && tsc -b",
    "preview": "vite preview",
    "test": "playwright install && vitest"
  },
  "dependencies": {
    "@tanstack/react-router": "1.168.22",
    "antd": "6.3.5",
    "dayjs": "1.11.20",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/router-plugin": "1.167.22",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser": "4.1.4",
    "@vitest/browser-playwright": "4.1.4",
    "autoprefixer": "10.5.0",
    "dotenv": "17.4.2",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.5.0",
    "playwright": "1.59.1",
    "postcss": "8.5.9",
    "prettier": "3.8.3",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.2",
    "vite": "8.0.8",
    "vitest": "4.1.4",
    "vitest-browser-react": "2.2.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "onFail": "error"
    }
  },
  "engines": {
    "node": "24.14.1",
    "pnpm": "10.33.0"
  }
}
